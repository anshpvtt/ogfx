# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ogfx?schema=public"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# CORS
CORS_ORIGIN="*"

# API URLs
API_URL=http://localhost:3001
WS_URL=ws://localhost:3001/ws

# Market Data APIs
BINANCE_API_URL=https://api.binance.com
TWELVEDATA_API_KEY=your_twelvedata_api_key

# Supabase (for signals, demo capital, demo orders, history)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Gemini/Gemma analyzer
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
GEMINI_API_KEY=your_google_generative_language_key
GOOGLE_GENERATIVE_AI_API_KEY=your_google_generative_language_key
GEMINI_MODEL=
AGENT_SECRET=change-this-agent-secret

# Trading Settings
LIVE_AGENT_ENABLED=true
LIVE_AGENT_INTERVAL_SECONDS=60
LIVE_AGENT_SIGNAL_GAP_MINUTES=15
LIVE_AGENT_ASSETS=XAUUSD,EURUSD,GBPUSD,USDJPY,BTCUSD,ETHUSD,USOIL,NAS100,SPX500
LIVE_AGENT_TIMEFRAMES=15m,1h
SIGNAL_INTERVAL_SECONDS=60
MAX_DAILY_SIGNALS=10
MIN_CONFIDENCE=68
